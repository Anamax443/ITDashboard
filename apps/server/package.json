{
  "name": "@itdashboard/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node scripts/build-info.mjs && tsx watch src/index.ts",
    "build": "node scripts/build-info.mjs && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretypecheck": "node scripts/build-info.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ldapts": "^8.1.8",
    "msnodesqlv8": "^4.4.0",
    "mssql": "^11.0.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
