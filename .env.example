# --- Server (apps/server) ---

# MSSQL on dedicated SQL server
SQL_HOST=10.8.2.225
SQL_INSTANCE=BCNEW
SQL_DATABASE=ITDashboard
# Use Windows Integrated Auth (Trusted Connection) — service account runs the API as
SQL_TRUSTED_CONNECTION=true
# Fallback SQL auth (NOT recommended for prod):
# SQL_USER=
# SQL_PASSWORD=

# API
API_PORT=4000
API_BIND=0.0.0.0

# Eventlog collector
COLLECTOR_POLL_INTERVAL_SEC=300
COLLECTOR_LEVELS=Warning,Error,Critical
COLLECTOR_LOGNAMES=System,Application,Security
# Retention
RETENTION_RAW_DAYS=90

# Alerting
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
RESEND_API_KEY=
TEAMS_WEBHOOK_URL=

# --- Desktop client (apps/desktop) ---
DESKTOP_API_BASE_URL=https://itdashboard.micos.local
