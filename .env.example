# =====================================================================
# ITDashboard — server runtime configuration (apps/server/.env)
# ---------------------------------------------------------------------
# Copy to .env on the API host and fill in for YOUR environment. The repo
# itself carries no IPs, hostnames or domain names — everything that is
# site-specific lives here. To stand the project up somewhere new you
# should only have to edit this file (plus the GitHub Actions variables
# listed at the bottom if you use the auto-deploy pipeline).
#
# Values marked [REQUIRED] must point at your environment. Everything else
# has a working default and is only for tuning.
# =====================================================================

# --- Database (MSSQL) ------------------------------------------------
# Auth is ALWAYS Windows Integrated (Trusted Connection) via the
# msnodesqlv8 driver — the API service runs under a domain service
# account that is mapped to a SQL login, so no SQL password is ever
# stored. SQL_USER / SQL_PASSWORD are intentionally NOT read by the code.
SQL_HOST=                 # [REQUIRED] SQL server IP or hostname, e.g. 10.0.0.10 / sql01.corp.local
SQL_INSTANCE=             # named instance, or leave EMPTY for the default instance
SQL_DATABASE=ITDashboard  # database name (created during setup)

# --- API server ------------------------------------------------------
API_PORT=4000
API_BIND=0.0.0.0          # 0.0.0.0 = all interfaces; 127.0.0.1 to bind loopback only
# Set to 1 ONLY when the API is fronted by TLS (e.g. IIS reverse proxy).
# Marks the session cookie Secure; do not enable on plain-HTTP :4000.
ITD_COOKIE_SECURE=0

# --- Active Directory: edit-tier login (LDAP bind) -------------------
# Comma-separated list of DC LDAP URLs for failover (one per DC; ldapts
# does not do SRV discovery). [REQUIRED] for the edit tier in production.
AD_LDAP_URL=              # e.g. ldap://dc01.corp.local:389,ldap://dc02.corp.local:389
AD_LDAP_DOMAIN=           # default UPN suffix for bare usernames, e.g. CORP.LOCAL (no hardcoded default)
AD_LDAP_BASE_DN=          # search root, e.g. DC=CORP,DC=LOCAL
AD_EDIT_GROUP=            # DN of the group gating the edit tier, e.g. CN=ITDashboard-Editors,OU=Groups,DC=CORP,DC=LOCAL
AD_LDAP_TIMEOUT_MS=5000
# Testing only: accept any non-empty credential WITHOUT a real DC. Refused
# when NODE_ENV=production. Leave unset for real deployments.
# AD_LDAP_STUB=1

NODE_ENV=production       # 'production' enforces the LDAP/edit-tier guards

# --- Collector cadence (fallbacks; live values come from Settings/DB) -
COLLECTOR_POLL_INTERVAL_SEC=300
DISK_POLL_INTERVAL_SEC=1800
SERVICES_POLL_INTERVAL_SEC=900

# --- MikroTik DHCP device inventory ----------------------------------
# Feeds the "Devices" tab from MikroTik DHCP leases. Router IPs, the RouterOS
# user and the password are configured in the dashboard UI (Settings →
# "MikroTik DHCP"), stored in the DB (the password ENCRYPTED, not plaintext).
#
# MIKROTIK_SECRET is the symmetric key used to encrypt/decrypt that password.
# It must be set to the SAME value on the API host AND on whichever host runs
# the DHCP sync (the SQL server in the reference deployment, which is the host
# allowed on the routers). Without it the password is stored unencrypted
# (clearly marked) and a warning is logged. Use a long random string.
MIKROTIK_SECRET=                  # e.g. a 32+ char random string; same on API host and sync host
#
# Legacy in-process collector (only if you run the pull FROM the API host):
# the API host must be allowed on the routers. Normally leave these UNSET and
# use the Settings UI + the external sync script instead.
# MIKROTIK_ROUTERS=Brno=10.8.2.207,Zastavka=10.10.181.2
# MIKROTIK_USER=dhcp-reader
# MIKROTIK_PASSWORD=
# MIKROTIK_INTERVAL_SEC=300

# --- Alerting / email reporting -------------------------------------
# Disk-critical email alerting IS implemented but is configured entirely in
# the Settings UI (DB settings table, alerts.* keys) — NOT here — so there are
# no env vars to set. Settings → "Email alerts — disks": enable, frequency,
# SMTP relay host/port, sender, recipients, dashboard link (alerts.dashboard_url);
# per-PC opt-in is the "📧 Disk" column in Computers. Off by default.
# Critical-SERVICE email alerts work the same way (Settings → "Email alerts —
# services", "🔔 Services" column): a configurable critical-service list +
# whitelist, with flapping protection (debounce minutes + optional maintenance
# window), plus optional phase-2 PORT checks (TCP-probe LDAP 389 / SMB 445 /
# RDP 3389 / Kerberos 88 / DNS 53 to test network→firewall→OS→service). Shares
# the same SMTP relay / recipients / dashboard URL.
# Reference deployment sends via Microsoft 365 Direct Send (host
# axima-cz.mail.protection.outlook.com, port 25, STARTTLS, no auth, From @axima.cz,
# own-domain recipients only). Teams/webhook delivery is not implemented.

# =====================================================================
# Desktop / browser client (apps/desktop)
# ---------------------------------------------------------------------
# The browser build is served BY the API and uses relative URLs — it needs
# no base URL. Set VITE_API_BASE only for the packaged Electron client,
# whose renderer has no same-origin server. Baked in at build time.
# VITE_API_BASE=https://itdashboard.corp.local
# =====================================================================

# =====================================================================
# Auto-deploy pipeline (GitHub Actions) — NOT read from this file.
# Set these as repository VARIABLES (Settings → Secrets and variables →
# Actions → Variables) so .github/workflows/deploy.yml can run migrations:
#   SQL_HOST, SQL_INSTANCE, SQL_DATABASE
# The self-hosted runner label in deploy.yml ([self-hosted, windows,
# itdashboard-prod]) must match a runner registered on your API host.
# =====================================================================
